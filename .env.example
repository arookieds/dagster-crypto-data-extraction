# Environment Configuration
# Copy this file to .env and update with your actual values
#
# IMPORTANT: Multi-Environment Support
# =====================================
# LOCAL DEVELOPMENT (Default):
#   - No PostgreSQL required!
#   - Data stored in .dagster_data/ directory
#   - Uses SQLite for parameters
#   - Uses DuckDB for crypto data
#   - Just run: dagster dev -f app/definitions.py
#
# PRODUCTION (Kubernetes):
#   - Requires PostgreSQL
#   - Set all POSTGRES_* environment variables
#   - System automatically detects and uses PostgreSQL
#   - Data stored in PostgreSQL database

# ============================================================================
# Environment
# ============================================================================
ENVIRONMENT=development  # Options: development, staging, production, test
LOG_LEVEL=INFO          # Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ============================================================================
# PostgreSQL Database Configuration (OPTIONAL for local dev)
# ============================================================================
# Leave these commented out for local development (uses SQLite + DuckDB)
# Uncomment and set for production deployment (uses PostgreSQL)
#
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_USER=crypto_user
# POSTGRES_PASSWORD=your_secure_password_here
# POSTGRES_DB=crypto_data

# ============================================================================
# Local Development Storage (used when PostgreSQL not configured)
# ============================================================================
# DATA_DIR=.dagster_data  # Directory for SQLite and DuckDB files (default)

# ============================================================================
# Data Extraction Settings
# ============================================================================
EXTRACTION_TIMEOUT=300  # Timeout for API calls in seconds
MAX_RETRIES=3          # Maximum number of retry attempts
RETRY_DELAY=5          # Delay between retries in seconds

# ============================================================================
# DLT (Data Load Tool) Configuration
# ============================================================================
# These are automatically configured based on environment:
# - Local Dev: Uses DuckDB (.dagster_data/crypto_data.duckdb)
# - Production: Uses PostgreSQL (connection from POSTGRES_* vars above)
DLT_PIPELINE_NAME=crypto_data_extraction

# ============================================================================
# S3/MinIO Configuration (OPTIONAL)
# ============================================================================
# Uncomment and set to use S3/MinIO for data storage
#
# S3_BUCKET_NAME=my-crypto-data-bucket
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY_ID=minioadmin
# S3_SECRET_ACCESS_KEY=minioadmin

# ============================================================================
# Enhanced S3 Configuration for dlt filesystem destination
# ============================================================================
# These variables are automatically used when use_s3=true
# They provide dlt with S3 bucket configuration and metadata support
#
# Example for MinIO:
# DESTINATION__FILESYSTEM__BUCKET_URL="s3://my-crypto-data-bucket"
# DESTINATION__FILESYSTEM__CREDENTIALS__AWS_ACCESS_KEY_ID="minioadmin"
# DESTINATION__FILESYSTEM__CREDENTIALS__AWS_SECRET_ACCESS_KEY="minioadmin"
# DESTINATION__FILESYSTEM__CREDENTIALS__ENDPOINT_URL="http://localhost:9000"
# DESTINATION__FILESYSTEM__KWARGS='{"auto_mkdir": true, "use_ssl": true}'
#
# Example for AWS S3:
# DESTINATION__FILESYSTEM__BUCKET_URL="s3://my-crypto-data-bucket"
# DESTINATION__FILESYSTEM__CREDENTIALS__AWS_ACCESS_KEY_ID="your_access_key"
# DESTINATION__FILESYSTEM__CREDENTIALS__AWS_SECRET_ACCESS_KEY="your_secret_key"
# DESTINATION__FILESYSTEM__KWARGS='{"auto_mkdir": true}'

# Example for MinIO (S3-compatible):
# DESTINATION__FILESYSTEM__BUCKET_URL="s3://my-crypto-data-bucket"
# DESTINATION__FILESYSTEM__CREDENTIALS__AWS_ACCESS_KEY_ID="minioadmin"
# DESTINATION__FILESYSTEM__CREDENTIALS__AWS_SECRET_ACCESS_KEY="minioadmin"
# DESTINATION__FILESYSTEM__CREDENTIALS__ENDPOINT_URL="http://localhost:9000"
# DESTINATION__FILESYSTEM__KWARGS='{"auto_mkdir": true, "use_ssl": false}'

# ============================================================================
# Exchange API Credentials (Optional)
# ============================================================================
# Only required if you need authenticated endpoints
# Leave empty for public data extraction (recommended for getting started)

# Binance
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=

# Gate.io
GATEIO_API_KEY=
GATEIO_API_SECRET=
